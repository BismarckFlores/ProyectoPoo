{
  "name": "portal-examen-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "start": "npm run dev",
    "dev:web": "npm run dev --workspace web",
    "dev:api": "npm run dev --workspace api",
    "dev": "concurrently -n WEB,API -c blue,green \"npm run dev:web\" \"npm run dev:api\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

